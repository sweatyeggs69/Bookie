# ── Booker Environment Variables ──────────────────────────
# Copy this file to .env and fill in the values

# ── Security (REQUIRED in production) ─────────────────────
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars

# ── Session Cookie ─────────────────────────────────────────
# Set to "false" if running over plain HTTP (e.g. behind a local reverse proxy)
# Defaults to "true" in production, "false" in debug mode
# SESSION_COOKIE_SECURE=false

# ── Network ────────────────────────────────────────────────
PORT=5000

# ── Limits ─────────────────────────────────────────────────
MAX_UPLOAD_MB=500
